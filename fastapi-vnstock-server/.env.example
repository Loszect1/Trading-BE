APP_NAME=VNStock Backend Service
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
VNSTOCK_API_KEY=your_api_key_here
CLAUDE_TOKEN=your_claude_token_here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_FALLBACK_MODEL=claude-3-5-haiku-latest
CLAUDE_MAX_TOKENS=1024
# Claude AI enrichment (optional, disabled by default for production safety)
# AI_CLAUDE_SIGNAL_SCORING_ENABLED=false
# AI_CLAUDE_SIGNAL_SCORING_MAX_TOKENS=500
# AI_CLAUDE_SIGNAL_SCORING_CACHE_TTL_SECONDS=1800
# AI_CLAUDE_EXPERIENCE_ENABLED=false
# AI_CLAUDE_EXPERIENCE_MAX_TOKENS=400
# AI_CLAUDE_EXPERIENCE_CACHE_TTL_SECONDS=3600
# AI_CLAUDE_AUTOMATION_LEVELS_ENABLED=false
# AI_CLAUDE_AUTOMATION_LEVELS_MAX_TOKENS=350
# AI_CLAUDE_AUTOMATION_LEVELS_CACHE_TTL_SECONDS=900
# AI_CLAUDE_FAILURE_COOLDOWN_SECONDS=45
DNSE_USERNAME=your_dnse_username
DNSE_PASSWORD=your_dnse_password
# Optional hint for FE / defaults (server-side REAL execution prefers DNSE_SUB_ACCOUNT when set)
# DNSE_DEFAULT_SUB_ACCOUNT=
# REAL execution: demo = simulated fills (default, safe); dnse_live = call DNSE (reject on outage, never silent-fill)
# REAL_EXECUTION_ADAPTER=demo
# Automated REAL + dnse_live: JWT from POST /dnse/auth/login and trading token from POST /dnse/auth/trading-token
# DNSE_ACCESS_TOKEN=
# DNSE_TRADING_TOKEN=
# DNSE_SUB_ACCOUNT=
# DNSE_ORDER_TYPE=LO
# DNSE_ASSET_TYPE=stock
# DNSE_EXECUTION_TIMEOUT_SECONDS=20
# DNSE_EXECUTION_PLACE_RETRIES=2
# DNSE_EXECUTION_POLL_ATTEMPTS=6
# DNSE_EXECUTION_POLL_INTERVAL_SECONDS=0.45
# Background trading-token refresh for dnse_live (optional; off by default). Requires DNSE_ACCESS_TOKEN.
# When smart_otp is false, set DNSE_REFRESH_OTP for each refresh attempt.
# DNSE_TRADING_TOKEN_REFRESH_ENABLED=false
# DNSE_TRADING_TOKEN_REFRESH_INTERVAL_SECONDS=300
# DNSE_TRADING_TOKEN_REFRESH_TIMEOUT_SECONDS=30
# DNSE_TRADING_TOKEN_REFRESH_SMART_OTP=true
# DNSE_REFRESH_OTP=
#
# --- Optional live E2E tests (DANGEROUS: real orders) — never enable in CI ---
# Requires RUN_DNSE_LIVE_TESTS=1 AND RUN_DNSE_LIVE_E2E=1; see README.
# Comma-separated tickers; DNSE_LIVE_E2E_SYMBOL must be one of them.
# DNSE_LIVE_E2E_SYMBOL_ALLOWLIST=VNM
# DNSE_LIVE_E2E_SYMBOL=VNM
# Optional caps (defaults: qty 1, max price 50_000; hard ceilings 100 / 1_000_000)
# DNSE_LIVE_E2E_MAX_QTY=1
# DNSE_LIVE_E2E_MAX_PRICE=50000
# DNSE_LIVE_E2E_QTY=1
# DNSE_LIVE_E2E_LIMIT_PRICE=1000
# DNSE_LIVE_E2E_SIDE=BUY
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/trading
REDIS_URL=your_redis_url
AI_CACHE_TTL_SECONDS=86400
# Firecrawl (GET /news/firecrawl/*) — lấy key tại https://www.firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
# Tuỳ chọn: timeout Firecrawl Search (ms)
# FIRECRAWL_SEARCH_TIMEOUT_MS=90000
# Số tin Firecrawl tối đa cho GET /news (mặc định 20, không vượt quá 20)
# NEWS_FIRECRAWL_TODAY_MAX=20
# Khi RSS lỗi: Firecrawl fallback theo domain (GET /news?use_firecrawl_rss_fallback=true)
# NEWS_FIRECRAWL_FALLBACK_PER_FEED=5
# NEWS_FIRECRAWL_FALLBACK_MAX_TOTAL=30
# NEWS_FIRECRAWL_FALLBACK_MAX_WORKERS=4
# TTL Redis cho POST /vnstock-api/listing/symbols-by-exchange và symbols-by-industries (giây), mặc định ~1 năm
LISTING_EXCHANGE_INDUSTRY_REDIS_TTL_SECONDS=31536000
# Short-term scanner cadence (minutes between runs; must divide 09:00–11:30 and 13:00–14:45 spans)
SHORT_TERM_SCAN_INTERVAL_MINUTES=15
# IANA timezone for VN regular session windows (schedule API + cron alignment)
SHORT_TERM_SCAN_TIMEZONE=Asia/Ho_Chi_Minh
# VN market holidays (scan grid + T+2 trading-day math). Union of: builtin JSON, optional file, CSV.
# Builtin curated list ships in app/data/vn_market_holidays_builtin.json (toggle off to rely only on file/CSV).
# VN_MARKET_HOLIDAYS_BUILTIN_ENABLED=true
# Local JSON: ["YYYY-MM-DD",...] or {"dates":["YYYY-MM-DD",...]} — no request-time network.
# VN_MARKET_HOLIDAYS_JSON_PATH=/path/to/vn_holidays.json
# Extra/ad-hoc dates (comma-separated YYYY-MM-DD), merged with the above
# VN_MARKET_HOLIDAYS_CSV=2026-01-01,2026-04-30,2026-09-02
# Internal scheduler loop (disabled by default)
# AUTOMATION_SHORT_TERM_SCHEDULER_ENABLED=false
# AUTOMATION_SHORT_TERM_SCHEDULER_POLL_SECONDS=30
# Pre-market liquidity warm cache (Mon-Fri, VN local time)
# AUTOMATION_SHORT_TERM_CACHE_WARM_ENABLED=false
# AUTOMATION_SHORT_TERM_CACHE_WARM_HOUR=7
# AUTOMATION_SHORT_TERM_CACHE_WARM_MINUTE=0
# Post-close refresh: update latest daily volume + rebuild Redis liquidity cache from DB (Mon-Fri, VN local time)
# AUTOMATION_SHORT_TERM_POST_CLOSE_REFRESH_ENABLED=true
# AUTOMATION_SHORT_TERM_POST_CLOSE_REFRESH_HOUR=16
# Optional override for multiple runs/day (comma-separated hours, local timezone), e.g. "12,16"
# AUTOMATION_SHORT_TERM_POST_CLOSE_REFRESH_HOURS_CSV=12,16
# AUTOMATION_SHORT_TERM_POST_CLOSE_REFRESH_MINUTE=0
# Daily volume retention window in DB (days)
# MARKET_SYMBOL_DAILY_VOLUME_RETENTION_DAYS=30

# Monitoring alert push channels (optional)
# MONITORING_TELEGRAM_BOT_TOKEN=123456:abc-def
# MONITORING_TELEGRAM_CHAT_ID=-1001234567890
# MONITORING_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# MONITORING_ALERT_DISPATCH_TIMEOUT_SECONDS=5
