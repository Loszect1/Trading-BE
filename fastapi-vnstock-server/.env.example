APP_NAME=VNStock Backend Service
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
VNSTOCK_API_KEY=your_api_key_here
CLAUDE_TOKEN=your_claude_token_here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_FALLBACK_MODEL=claude-3-5-haiku-latest
CLAUDE_MAX_TOKENS=1024
DNSE_USERNAME=your_dnse_username
DNSE_PASSWORD=your_dnse_password
REDIS_URL=your_redis_url
AI_CACHE_TTL_SECONDS=86400
# Firecrawl (GET /news/firecrawl/*) — lấy key tại https://www.firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
# Tuỳ chọn: timeout Firecrawl Search (ms)
# FIRECRAWL_SEARCH_TIMEOUT_MS=90000
# Số tin Firecrawl tối đa cho GET /news (mặc định 20, không vượt quá 20)
# NEWS_FIRECRAWL_TODAY_MAX=20
# Khi RSS lỗi: Firecrawl fallback theo domain (GET /news?use_firecrawl_rss_fallback=true)
# NEWS_FIRECRAWL_FALLBACK_PER_FEED=5
# NEWS_FIRECRAWL_FALLBACK_MAX_TOTAL=30
# NEWS_FIRECRAWL_FALLBACK_MAX_WORKERS=4
# TTL Redis cho POST /vnstock-api/listing/symbols-by-exchange và symbols-by-industries (giây), mặc định ~1 năm
LISTING_EXCHANGE_INDUSTRY_REDIS_TTL_SECONDS=31536000
