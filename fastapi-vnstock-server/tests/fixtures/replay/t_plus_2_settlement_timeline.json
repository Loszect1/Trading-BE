      "iso_utc": "2026-01-05T10:00:00Z"
    },
    {
      "op": "place_order",
      "expect": { "status": "FILLED" },
      "payload": {
        "account_mode": "DEMO",
        "symbol": "TSTFIX",
        "side": "BUY",
        "quantity": 25,
        "price": 9000.0,
        "idempotency_key": "replay-tstfix-buy",
